<script>
const state = {
  propType: 'house',
  condition: 'new',
  payRatio: 30,
  usePair: false,
  splitMode: 'income',
  _lastPrice: null,
  _loanManuallySet: false,
  currentRecordId: null,
  _booting: true,
};

const STORAGE_KEY = 'capitalplan_records_v1';
const CURRENT_KEY = 'capitalplan_current_v1';

function setPropType(t) {
  state.propType = t;
  document.querySelectorAll('.prop-card').forEach(el => el.classList.toggle('active', el.dataset.type === t));
  calc();
}

function setCondition(c) {
  state.condition = c;
  document.querySelectorAll('[data-cond]').forEach(el => el.classList.toggle('active', el.dataset.cond === c));
  calc();
}

function setRatio(r) {
  state.payRatio = r;
  document.querySelectorAll('[data-ratio]').forEach(el => el.classList.toggle('active', parseInt(el.dataset.ratio) === r));
  calc();
}

function setSplit(m) {
  state.splitMode = m;
  document.querySelectorAll('[data-split]').forEach(el => el.classList.toggle('active', el.dataset.split === m));
  document.getElementById('manualSplit').style.display = (m === 'manual') ? 'block' : 'none';
  calc();
}

function togglePair() {
  state.usePair = document.getElementById('usePair').checked;
  document.getElementById('pairSection').classList.toggle('active', state.usePair);
  document.getElementById('pairBreakdown').style.display = state.usePair ? 'grid' : 'none';
  calc();
}

function toggleSection(id) {
  document.getElementById(id).classList.toggle('collapsed');
}

function adjust(id, delta) {
  const el = document.getElementById(id);
  el.value = Math.max(0, (parseInt(el.value)||0) + delta);
  if (id === 'loan') state._loanManuallySet = true;
  calc();
}

function switchView(v) {
  document.body.classList.remove('view-input', 'view-result');
  document.body.classList.add('view-' + v);
  document.querySelectorAll('.mobile-tab[data-view]').forEach(el => el.classList.toggle('active', el.dataset.view === v));
  window.scrollTo({top: 0, behavior: 'smooth'});
}

function markEdited(el) { el.dataset.edited = '1'; }

function val(id) { return parseFloat(document.getElementById(id).value) || 0; }

function calc() {
  document.getElementById('reviewRateLabel').textContent = val('reviewRate').toFixed(1) + '%';
  document.getElementById('realRateLabel').textContent = val('realRate').toFixed(2) + '%';

  const reviewRate = val('reviewRate') / 100 / 12;
  const years = val('years');
  const n = years * 12;

  const age1 = val('age1');
  const income1 = val('income1');
  const age2 = val('age2');
  const income2 = val('income2');
  const totalIncome = state.usePair ? (income1 + income2) : income1;

  const debt1 = val('car1') + val('card1') + val('shop1') + val('revo1') + val('other1');
  const debt2 = state.usePair ? (val('car2') + val('card2') + val('shop2') + val('revo2') + val('other2')) : 0;
  const totalDebt = debt1 + debt2;

  const annualCap = totalIncome * 10000 * (state.payRatio / 100) - totalDebt * 12;
  const monthlyCap = Math.max(0, annualCap / 12);

  let capacity = 0;
  if (reviewRate > 0 && n > 0) {
    capacity = monthlyCap * (1 - Math.pow(1 + reviewRate, -n)) / reviewRate;
  }
  const capacityLimit = totalIncome * 10 * 10000;
  capacity = Math.min(capacity, capacityLimit);

  document.getElementById('capacity').textContent = Math.round(capacity / 10000).toLocaleString();

  const ageWarn = document.getElementById('ageWarning');
  const maxAge = Math.max(age1, state.usePair ? age2 : 0);
  if (maxAge + years > 79) {
    ageWarn.innerHTML = '<div class="warning">完済時年齢が79歳超</div>';
  } else {
    ageWarn.innerHTML = '';
  }

  let ratio1 = 1, ratio2 = 0;
  if (state.usePair) {
    if (state.splitMode === 'income') {
      const sum = income1 + income2;
      ratio1 = sum > 0 ? income1 / sum : 0.5;
      ratio2 = sum > 0 ? income2 / sum : 0.5;
    } else if (state.splitMode === 'half') {
      ratio1 = 0.5; ratio2 = 0.5;
    } else {
      const l1 = val('loan1'); const l2 = val('loan2');
      const sum = l1 + l2;
      ratio1 = sum > 0 ? l1 / sum : 0.5;
      ratio2 = sum > 0 ? l2 / sum : 0.5;
    }
    document.getElementById('ratio1').textContent = Math.round(ratio1 * 100) + '%';
    document.getElementById('ratio2').textContent = Math.round(ratio2 * 100) + '%';
  } else {
    document.getElementById('ratio1').textContent = '—';
    document.getElementById('ratio2').textContent = '—';
  }

  const realRate = val('realRate') / 100 / 12;
  const loanMan = val('loan');
  const loanYen = loanMan * 10000;
  const bonusMan = val('bonus');
  const bonusYen = bonusMan * 10000;

  const bonusTotal = bonusYen * 2 * years;
  const principalForMonthly = Math.max(0, loanYen - bonusTotal);

  let monthlyPay = 0;
  let totalPay = 0;
  let firstInterest = 0;
  if (realRate > 0 && principalForMonthly > 0) {
    monthlyPay = principalForMonthly * realRate * Math.pow(1 + realRate, n) / (Math.pow(1 + realRate, n) - 1);
    firstInterest = principalForMonthly * realRate;
  } else if (principalForMonthly > 0) {
    monthlyPay = principalForMonthly / n;
  }

  let bonusMonthlyPay = 0;
  if (realRate > 0 && bonusTotal > 0) {
    const br = realRate * 6;
    const bn = years * 2;
    bonusMonthlyPay = bonusTotal * br * Math.pow(1+br, bn) / (Math.pow(1+br, bn) - 1);
  } else if (bonusTotal > 0) {
    bonusMonthlyPay = bonusTotal / (years * 2);
  }

  totalPay = monthlyPay * n + bonusMonthlyPay * years * 2;
  const totalInterest = totalPay - loanYen;

  const maint = val('kanri') + val('shuzen') + val('parking');
  const monthlyTotal = monthlyPay + maint;
  const annualTotal = monthlyPay * 12 + bonusMonthlyPay * 2 + maint * 12;

  document.getElementById('monthlyTotal').textContent = Math.round(monthlyTotal).toLocaleString();
  document.getElementById('monthlyPrincipal').textContent = Math.round(monthlyPay - firstInterest).toLocaleString() + '円';
  document.getElementById('monthlyInterest').textContent = Math.round(firstInterest).toLocaleString() + '円';
  document.getElementById('monthlyMaint').textContent = Math.round(maint).toLocaleString() + '円';
  document.getElementById('annualTotal').textContent = Math.round(annualTotal).toLocaleString();
  document.getElementById('totalPayment').textContent = Math.round(totalPay / 10000).toLocaleString();
  document.getElementById('totalInterestSub').textContent = 'うち利息 ' + Math.round(totalInterest / 10000).toLocaleString() + '万円';

  if (state.usePair) {
    document.getElementById('pb1loan').textContent = Math.round(loanMan * ratio1).toLocaleString() + '万円';
    document.getElementById('pb2loan').textContent = Math.round(loanMan * ratio2).toLocaleString() + '万円';
    document.getElementById('pb1monthly').textContent = Math.round(monthlyPay * ratio1).toLocaleString() + '円';
    document.getElementById('pb2monthly').textContent = Math.round(monthlyPay * ratio2).toLocaleString() + '円';
    document.getElementById('pb1total').textContent = Math.round(totalPay * ratio1 / 10000).toLocaleString() + '万円';
    document.getElementById('pb2total').textContent = Math.round(totalPay * ratio2 / 10000).toLocaleString() + '万円';
  }

  const priceMan = val('price');
  const priceYen = priceMan * 10000;
  const reformMan = val('reform');

  // 借入額自動スライド
  if (state._booting) {
    state._lastPrice = priceMan;
  } else if (state._lastPrice !== priceMan) {
    if (!state._loanManuallySet) {
      const suggestedLoan = Math.round(priceMan * 1.085 / 10) * 10;
      document.getElementById('loan').value = suggestedLoan;
    }
    state._lastPrice = priceMan;
  }

  // 諸費用計算
  let chukai_calc = 0;
  if (priceYen > 4_000_000) chukai_calc = (priceYen * 0.03 + 60_000) * 1.1;
  else if (priceYen > 2_000_000) chukai_calc = (priceYen * 0.04 + 20_000) * 1.1;
  else if (priceYen > 0) chukai_calc = priceYen * 0.05 * 1.1;

  function baibaiInshi(yen) {
    if (yen <= 0) return 0;
    if (yen <= 5_000_000) return 1_000;
    if (yen <= 10_000_000) return 5_000;
    if (yen <= 50_000_000) return 10_000;
    if (yen <= 100_000_000) return 30_000;
    if (yen <= 500_000_000) return 60_000;
    return 100_000;
  }
  const inshiBaibai_calc = baibaiInshi(priceYen);

  function ukeoiInshi(yen) {
    if (yen <= 0) return 0;
    if (yen <= 2_000_000) return 200;
    if (yen <= 3_000_000) return 500;
    if (yen <= 5_000_000) return 1_000;
    if (yen <= 10_000_000) return 5_000;
    if (yen <= 50_000_000) return 10_000;
    if (yen <= 100_000_000) return 30_000;
    return 60_000;
  }
  const inshiUkeoi_calc = (state.propType === 'custom') ? ukeoiInshi(priceYen) : 0;

  const bank_calc = loanYen * 0.022 * (state.usePair ? 1.03 : 1);
  const fire_calc = state.propType === 'mansion' ? 80_000 : (priceYen > 50_000_000 ? 200_000 : 150_000);
  const touki_calc = state.condition === 'new'
    ? priceYen * 0.006 + loanYen * 0.001 + 150_000
    : priceYen * 0.008 + loanYen * 0.001 + 150_000;
  const hyouji_calc = (state.condition === 'new') ? 110_000 : 0;
  const kikin_calc = (state.propType === 'mansion' && state.condition === 'new') ? 400_000 : 0;
  const kanriSei_calc = val('kanri') > 0 ? val('kanri') : (state.propType === 'mansion' ? 15_000 : 0);
  const shuzenSei_calc = val('shuzen') > 0 ? val('shuzen') : (state.propType === 'mansion' ? 10_000 : 0);
  const kotei_calc = priceYen * 0.003;
  const shutoku_calc = state.condition === 'used' ? priceYen * 0.01 : priceYen * 0.003;

  function syncCost(id, v) {
    const el = document.getElementById(id);
    if (!el) return;
    if (!el.dataset.edited) el.value = Math.round(v);
  }
  syncCost('ci_chukai', chukai_calc);
  syncCost('ci_inshi1', inshiBaibai_calc);
  syncCost('ci_inshi2', inshiUkeoi_calc);
  syncCost('ci_bank', bank_calc);
  syncCost('ci_fire', fire_calc);
  syncCost('ci_touki', touki_calc);
  syncCost('ci_hyouji', hyouji_calc);
  syncCost('ci_kikin', kikin_calc);
  syncCost('ci_kanri_sei', kanriSei_calc);
  syncCost('ci_shuzen_sei', shuzenSei_calc);
  syncCost('ci_kotei', kotei_calc);
  syncCost('ci_furikomi', 5_500);
  syncCost('ci_shutoku', shutoku_calc);
  syncCost('ci_reform_yen', reformMan * 10_000);

  function cVal(id) { return parseFloat(document.getElementById(id)?.value) || 0; }
  const totalCost = cVal('ci_chukai') + cVal('ci_inshi1') + cVal('ci_inshi2')
                  + cVal('ci_bank') + cVal('ci_fire') + cVal('ci_touki')
                  + cVal('ci_hyouji') + cVal('ci_kikin') + cVal('ci_kanri_sei')
                  + cVal('ci_shuzen_sei') + cVal('ci_kotei') + cVal('ci_furikomi');
  const propTotal = priceMan + Math.round(totalCost / 10000) + Math.round(cVal('ci_reform_yen') / 10000);
  const cashOut = Math.max(0, propTotal - loanMan);

  document.getElementById('propTotal').textContent = propTotal.toLocaleString();
  document.getElementById('cashOut').textContent = cashOut.toLocaleString();
  document.getElementById('t_total').textContent = propTotal.toLocaleString();
  document.getElementById('t_loan').textContent = loanMan.toLocaleString();
  document.getElementById('t_cash').textContent = cashOut.toLocaleString();

  const loanWarn = document.getElementById('loanWarning');
  if (loanYen > capacity && capacity > 0) {
    loanWarn.innerHTML = '<div class="warning danger">借入額が借入可能総額を超過</div>';
  } else {
    loanWarn.innerHTML = '';
  }

  if (!state._booting) autoSave();
}

function resetCostInputs() {
  if (!confirm('諸費用をすべて自動計算値に戻しますか？')) return;
  document.querySelectorAll('.cost-input').forEach(el => delete el.dataset.edited);
  calc();
}

// AUTO SAVE
let saveTimer = null;

function getInputSnapshot() {
  const snapshot = { _state: {
    propType: state.propType,
    condition: state.condition,
    payRatio: state.payRatio,
    splitMode: state.splitMode,
    _loanManuallySet: state._loanManuallySet,
  }, inputs: {}, costEdits: {} };
  document.querySelectorAll('input[type="number"], input[type="text"], textarea').forEach(el => {
    if (el.id) snapshot.inputs[el.id] = el.value;
  });
  snapshot.inputs.usePair = document.getElementById('usePair').checked;
  document.querySelectorAll('.cost-input').forEach(el => {
    if (el.dataset.edited) snapshot.costEdits[el.id] = true;
  });
  return snapshot;
}

function applySnapshot(snap) {
  if (!snap) return;
  state._booting = true;
  Object.entries(snap.inputs || {}).forEach(([id, v]) => {
    const el = document.getElementById(id);
    if (!el) return;
    if (el.type === 'checkbox') el.checked = !!v;
    else el.value = v;
  });
  document.querySelectorAll('.cost-input').forEach(el => delete el.dataset.edited);
  Object.keys(snap.costEdits || {}).forEach(id => {
    const el = document.getElementById(id);
    if (el) el.dataset.edited = '1';
  });
  if (snap._state) {
    state.propType = snap._state.propType || 'house';
    state.condition = snap._state.condition || 'new';
    state.payRatio = snap._state.payRatio || 30;
    state.splitMode = snap._state.splitMode || 'income';
    state._loanManuallySet = !!snap._state._loanManuallySet;
  }
  setPropType(state.propType);
  setCondition(state.condition);
  setRatio(state.payRatio);
  setSplit(state.splitMode);
  togglePair();
  state._booting = false;
  calc();
}

function getAllRecords() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
  catch(e) { return {}; }
}

function saveAllRecords(records) {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(records)); }
  catch(e) { console.error(e); }
}

function showSaveIndicator() {
  const el = document.getElementById('saveIndicator');
  el.classList.add('show');
  clearTimeout(el._t);
  el._t = setTimeout(() => el.classList.remove('show'), 1500);
}

function autoSave() {
  if (state._booting) return;
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    const snapshot = getInputSnapshot();
    const custName = document.getElementById('custName').value.trim();

    try { localStorage.setItem(CURRENT_KEY, JSON.stringify(snapshot)); } catch(e) {}

    if (state.currentRecordId) {
      const records = getAllRecords();
      records[state.currentRecordId] = {
        id: state.currentRecordId,
        name: custName || '（無題）',
        updatedAt: new Date().toISOString(),
        snapshot: snapshot,
      };
      saveAllRecords(records);
      refreshRecordSelect();
    }
    showSaveIndicator();
  }, 400);
}

function saveAsNew() {
  let custName = document.getElementById('custName').value.trim();
  if (!custName) {
    const input = prompt('顧客名を入力してください', '');
    if (!input) return;
    custName = input.trim();
    document.getElementById('custName').value = custName;
  }
  const id = 'rec_' + Date.now();
  state.currentRecordId = id;
  const records = getAllRecords();
  records[id] = {
    id,
    name: custName || '（無題）',
    updatedAt: new Date().toISOString(),
    snapshot: getInputSnapshot(),
  };
  saveAllRecords(records);
  refreshRecordSelect();
  document.getElementById('recordSelect').value = id;
  showSaveIndicator();
  alert(custName + ' として保存しました');
}

function switchRecord() {
  const id = document.getElementById('recordSelect').value;
  if (!id) {
    if (!confirm('現在の内容を破棄して新規作成しますか？')) {
      document.getElementById('recordSelect').value = state.currentRecordId || '';
      return;
    }
    state.currentRecordId = null;
    state._loanManuallySet = false;
    resetAllFields();
    calc();
    return;
  }
  const records = getAllRecords();
  const rec = records[id];
  if (!rec) return;
  state.currentRecordId = id;
  applySnapshot(rec.snapshot);
}

function refreshRecordSelect() {
  const records = getAllRecords();
  const select = document.getElementById('recordSelect');
  const current = state.currentRecordId;
  select.innerHTML = '<option value="">— 新規作成 —</option>';
  Object.values(records)
    .sort((a, b) => b.updatedAt.localeCompare(a.updatedAt))
    .forEach(rec => {
      const opt = document.createElement('option');
      opt.value = rec.id;
      const date = new Date(rec.updatedAt);
      opt.textContent = rec.name + ' (' + (date.getMonth()+1) + '/' + date.getDate() + ')';
      select.appendChild(opt);
    });
  if (current) select.value = current;
}

function openRecords() {
  const records = getAllRecords();
  const list = document.getElementById('recordList');
  const items = Object.values(records).sort((a, b) => b.updatedAt.localeCompare(a.updatedAt));
  if (items.length === 0) {
    list.innerHTML = '<div style="color:var(--text-mute);font-family:var(--jp-serif);font-size:13px;padding:20px;text-align:center;">まだ記録がありません<br>💾ボタンで新規保存</div>';
  } else {
    list.innerHTML = '';
    items.forEach(rec => {
      const div = document.createElement('div');
      div.className = 'record-item';
      const date = new Date(rec.updatedAt);
      const dstr = date.getFullYear() + '/' + (date.getMonth()+1) + '/' + date.getDate()
                 + ' ' + String(date.getHours()).padStart(2,'0') + ':' + String(date.getMinutes()).padStart(2,'0');
      const priceMan = rec.snapshot?.inputs?.price || '—';
      div.innerHTML =
        '<div class="record-info" onclick="loadRecord(\'' + rec.id + '\')">' +
          '<div class="record-name">' + escapeHtml(rec.name) + '</div>' +
          '<div class="record-meta">更新: ' + dstr + ' ／ 物件 ' + priceMan + '万円</div>' +
        '</div>' +
        '<button class="record-del" onclick="deleteRecord(\'' + rec.id + '\')" title="削除">🗑️</button>';
      list.appendChild(div);
    });
  }
  document.getElementById('recordsModal').classList.add('show');
}

function closeRecords() {
  document.getElementById('recordsModal').classList.remove('show');
}

function loadRecord(id) {
  const records = getAllRecords();
  const rec = records[id];
  if (!rec) return;
  state.currentRecordId = id;
  applySnapshot(rec.snapshot);
  document.getElementById('recordSelect').value = id;
  closeRecords();
}

function deleteRecord(id) {
  if (!confirm('この記録を削除しますか？')) return;
  const records = getAllRecords();
  delete records[id];
  saveAllRecords(records);
  if (state.currentRecordId === id) state.currentRecordId = null;
  refreshRecordSelect();
  openRecords();
}

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, c =>
    ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function resetAllFields() {
  const defaults = {
    age1: 35, income1: 500, age2: 33, income2: 400,
    years: 35, price: 4500, loan: 4883,
    car1:0, card1:0, shop1:0, revo1:0, other1:0,
    car2:0, card2:0, shop2:0, revo2:0, other2:0,
    loan1:0, loan2:0, bonus:0, kanri:0, shuzen:0, parking:0, reform:0,
    reviewRate: 3.0, realRate: 0.5,
  };
  Object.entries(defaults).forEach(([id, v]) => {
    const el = document.getElementById(id);
    if (el) el.value = v;
  });
  document.querySelectorAll('.cost-input').forEach(el => delete el.dataset.edited);
  document.getElementById('usePair').checked = false;
  document.getElementById('custName').value = '';
  document.getElementById('memo').value = '';
  togglePair();
  setPropType('house');
  setCondition('new');
  setRatio(30);
  setSplit('income');
}

async function captureImage(ev) {
  const btn = ev?.target;
  const orig = btn?.textContent;
  if (btn) { btn.textContent = '生成中…'; btn.disabled = true; }
  try {
    const canvas = await html2canvas(document.getElementById('captureTarget'), {
      backgroundColor: '#ffffff',
      scale: 2,
      useCORS: true,
      logging: false
    });
    const custName = document.getElementById('custName').value.trim() || '資金計画';
    const link = document.createElement('a');
    link.download = custName + '_' + new Date().toISOString().slice(0,10) + '.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  } catch(e) {
    alert('保存に失敗しました。スクリーンショットをお試しください');
  }
  if (btn) { btn.textContent = orig; btn.disabled = false; }
}

// INIT
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('loan').addEventListener('input', () => {
    if (!state._booting) state._loanManuallySet = true;
  });

  try {
    const saved = localStorage.getItem(CURRENT_KEY);
    if (saved) {
      const snap = JSON.parse(saved);
      applySnapshot(snap);
    }
  } catch(e) {}

  // URLパラメータで上書き (保存データより優先)
  const params = new URLSearchParams(window.location.search);
  const paramMap = {
    price: 'price',
    income: 'income1',
    age: 'age1',
    loan: 'loan'
  };
  
  let paramOverridden = false;

  for (const [key, id] of Object.entries(paramMap)) {
    if (params.has(key)) {
      const val = parseInt(params.get(key));
      const el = document.getElementById(id);
      if (!isNaN(val) && el) {
        el.value = val;
        paramOverridden = true;
      }
    }
  }

  if (paramOverridden) {
    if (params.has('price') && !params.has('loan')) {
      state._loanManuallySet = false;
    } else if (params.has('loan')) {
      state._loanManuallySet = true;
    }
  }

  state._booting = false;
  calc();

  refreshRecordSelect();
});
</script>

